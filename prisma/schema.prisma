// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}




datasource db {
  provider = "postgresql"
}





model Patient {
  id             String       @id @default(cuid())
  name           String
  birth_date     DateTime?
  age            Int?
  gender         String?
  dominance      String?
  activity_level String?
  created_at     DateTime?    @default(now()) @db.Timestamptz(6)
  created_by_id  String?
  change_logs    Json?

  assessments    Assessment[]
  created_by     User?        @relation("PatientCreatedBy", fields: [created_by_id], references: [id])

  @@map("patients")
}

model Assessment {
  id                    String    @id @default(cuid())
  patient_id            String
  assessment_type       String
  segment               String
  clinical_data         Json?
  questionnaire_answers Json?
  created_at            DateTime? @default(now()) @db.Timestamptz(6)
  created_by_id         String?
  change_logs           Json?

  patient               Patient   @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  created_by            User?        @relation("AssessmentCreatedBy", fields: [created_by_id], references: [id])

  @@map("assessments")
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  password              String
  name                  String
  role                  String    @default("ASSISTENTE") // ADMINISTRADOR, FISIOTERAPEUTA, ASSISTENTE
  crefito               String?
  avatar_url            String?

  birth_date            DateTime?
  is_active             Boolean   @default(true)
  force_password_change Boolean   @default(false)
  created_at            DateTime? @default(now()) @db.Timestamptz(6)
  change_logs           Json?

  created_patients      Patient[]    @relation("PatientCreatedBy")
  created_assessments   Assessment[] @relation("AssessmentCreatedBy")
  templates_created     AssessmentTemplate[] @relation("TemplateCreatedBy")

  @@map("users")
}

model AssessmentTemplate {
  id            String   @id @default(cuid())
  title         String
  description   String?
  segment       String
  icon_url      String?
  structure     Json     // Questionáio (perguntas, seções, etc)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  created_by_id String?
  change_logs   Json?

  created_by    User?    @relation("TemplateCreatedBy", fields: [created_by_id], references: [id])

  @@map("assessment_templates")
}


